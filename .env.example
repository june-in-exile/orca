ORCA_PORT=8080
ORCA_STORAGE_DIR=./storage
ORCA_MAX_FILE_SIZE_MB=500
# ORCA_FFMPEG_PATH=ffmpeg
# ORCA_FFPROBE_PATH=ffprobe
ORCA_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
ORCA_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Storage backend: "local" (default) or "walrus"
# ORCA_STORAGE_BACKEND=local
# ORCA_WALRUS_CACHE_DIR=./storage/walrus-cache
# ORCA_WALRUS_CACHE_MAX_MB=2048
# ORCA_WALRUS_EPOCHS=1
# ORCA_GATEWAY_URL=http://localhost:8080

# Sui network for wallet integration (testnet or mainnet)
# ORCA_SUI_NETWORK=testnet